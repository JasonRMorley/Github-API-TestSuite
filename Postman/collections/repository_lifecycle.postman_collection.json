    {
      "name": "update_repo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"Repository owner is correct\", function () {\r",
              "    pm.expect(data.owner.login).to.eql(pm.environment.get(\"repoOwner\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Repository name is unchanged\", function () {\r",
              "    pm.expect(data.name).to.eql(pm.environment.get(\"repoName\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Description was updated\", function () {\r",
              "    pm.expect(data.description).to.eql(pm.environment.get(\"updatedDescription\"));\r",
              "});\r",
              "\r",
              "pm.test(\"has_issues was updated\", function () {\r",
              "    pm.expect(data.has_issues).to.eql(true);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
