  "item": [
    {
      "name": "create_repo",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const repoName = \"My_repo-\" + Date.now();\r",
              "pm.environment.set(\"repoName\", repoName);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const repoId = pm.response.json().id;\r",
              "const repoName = pm.response.json().name;\r",
              "const repoFullname = pm.response.json().full_name;\r",
              "const repoOwner = pm.response.json().owner.login;\r",
              "\r",
              "console.log(repoFullname)\r",
              "\r",
              "pm.environment.set(\"repoId\", repoId);\r",
              "pm.environment.set(\"repoName\", repoName);\r",
              "pm.environment.set(\"repoFullname\", repoFullname);\r",
              "pm.environment.set(\"repoOwner\", repoOwner);\r",
              "\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Repository name is correct\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data.name).to.eql(pm.environment.get(\"repoName\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Repository owner is correct\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data.owner.login).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2022-11-28"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "User-Agent",
            "value": "PostmanRuntime"
          },
          {
            "key": "accept",
            "value": "application/vnd.github+json",
            "disabled": true
          },
          {
            "key": "Authorization",
            "value": "{{github_fine_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{repoName}}\",\n  \"description\": \"This is a test repo that shouldnt exist\",\n  \"private\": true,\n  \"auto_init\": false\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/user/repos",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "user",
            "repos"
          ]
        }
      },
      "response": []
    },
    {
      "name": "get_repo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.test(\"Repository name matches expected value\", function () {",
              "    pm.expect(data.name).to.eql(pm.environment.get(\"repoName\"));",
              "});",
              "",
              "pm.test(\"Repository full name matches expected value\", function () {",
              "    pm.expect(data.full_name).to.eql(pm.environment.get(\"repoFullname\"));",
              "});",
              "",
              "pm.test(\"Important fields exist\", function () {",
              "    pm.expect(data.id).to.exist;",
              "    pm.expect(data.name).to.exist;",
              "    pm.expect(data.full_name).to.exist;",
              "    pm.expect(data.owner.login).to.exist;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
