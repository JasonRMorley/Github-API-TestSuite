  "item": [
    {
      "name": "create_repo",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const repoName = \"My_repo-\" + Date.now();\r",
              "pm.environment.set(\"repoName\", repoName);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "if (pm.response.code !== 201) {\r",
              "    return;\r",
              "}\r",
              "\r",
              "const createRepoData = pm.response.json();\r",
              "const expectedRepoName = pm.environment.get(\"repoName\");\r",
              "\r",
              "pm.environment.set(\"repoId\", createRepoData.id);\r",
              "pm.environment.set(\"repoName\", createRepoData.name);\r",
              "pm.environment.set(\"repoFullname\", createRepoData.full_name);\r",
              "pm.environment.set(\"repoOwner\", createRepoData.owner.login);\r",
              "\r",
              "pm.test(\"Repository name is correct\", function () {\r",
              "    pm.expect(createRepoData.name).to.eql(expectedRepoName);\r",
              "});\r",
              "\r",
              "pm.test(\"Repository owner is correct\", function () {\r",
              "    pm.expect(createRepoData.owner.login).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2022-11-28"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "User-Agent",
            "value": "PostmanRuntime"
          },
          {
            "key": "accept",
            "value": "application/vnd.github+json",
            "disabled": true
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{repoName}}\",\n  \"description\": \"This is a test repo that shouldnt exist\",\n  \"private\": true,\n  \"auto_init\": false\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
