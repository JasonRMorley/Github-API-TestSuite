      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const getRepoData = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.test(\"Repository name matches expected value\", function () {",
              "    pm.expect(getRepoData.name).to.eql(pm.environment.get(\"repoName\"));",
              "});",
              "",
              "pm.test(\"Repository full name matches expected value\", function () {",
              "    pm.expect(getRepoData.full_name).to.eql(pm.environment.get(\"repoFullname\"));",
              "});",
              "",
              "pm.test(\"Important fields exist\", function () {",
              "    pm.expect(getRepoData.id).to.exist;",
              "    pm.expect(getRepoData.name).to.exist;",
              "    pm.expect(getRepoData.full_name).to.exist;",
              "    pm.expect(getRepoData.owner.login).to.exist;",
              "});"
            ],
